class Solution {
    public int minCostToMoveChips(int[] position) {
      int cost=0,count1=0,count2=0;
      for(int i=0;i<position.length;i++)
      {
        if(position[i]%2!=0)
        {
            count1++;
        }
        else
        {
            count2++;
        }
      }
      return (count1<count2)?count1:count2;
    }
}