class Solution {
    public int maximumWealth(int[][] accounts) {
        int rsum=0,max=Integer.MIN_VALUE;
        for(int i=0;i<accounts.length;i++)
        {
            for(int j=0;j<accounts[0].length;j++)
            {
                rsum+=accounts[i][j];
            }
            if(rsum>max)
            {
                max=rsum;
            }
            rsum=0;
        }
        return max;
    }
}
