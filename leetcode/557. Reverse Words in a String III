class Solution {
    public String reverseWords(String s) {
        String[] arr=s.split(" ");
        String str="";
        for(int i=0;i<arr.length;i++)
        {
            StringBuilder sb1=new StringBuilder(arr[i]);
            str+=sb1.reverse().toString(); 
            if(i!=arr.length-1)
            {
                str+=" ";
            }
        }
        return str;
    }
}
