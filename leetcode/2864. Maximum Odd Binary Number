class Solution {
    public String maximumOddBinaryNumber(String s) {
        int onecount=0,zerocount=0;
        StringBuilder sb=new StringBuilder();
        int n=s.length();
        for(int i=0;i<n;i++)
        {
            if(s.charAt(i)=='1')
            {
                onecount++;
            }
            else 
            {
                zerocount++;
            }
        }
        for(int i=0;i<onecount-1;i++)
        {
            sb.append('1');
        }
        for(int i=0;i<zerocount;i++)
        {
            sb.append('0');
        }
        sb.append('1');
        return sb.toString();

    }
}